# Environment Configuration
# Copy this file to .env and fill in your values
#
# FREE OPEN-SOURCE LLM PROVIDERS (Recommended for trial/deployment):
# -----------------------------------------------------------------
# 1. GROQ - https://console.groq.com
#    - FREE tier: 30 requests/min, 14,400 requests/day
#    - Models: llama-3.3-70b-versatile, mixtral-8x7b-32768, gemma-7b-it
#    - Sign up with GitHub/Google
#
# 2. HUGGING FACE - https://huggingface.co
#    - FREE tier: Inference Endpoints (limited hours)
#    - Models: meta-llama/Llama-3.3-70B-Instruct, mistralai/Mistral-7B-Instruct
#    - Sign up with GitHub
#
# 3. COHERE - https://cohere.com
#    - FREE trial: 1000 tokens/month
#    - Models: command-r-plus, command-r
#
# 4. MISTRAL - https://mistral.ai
#    - FREE tier available
#    - Models: mistral-large-latest, mistral-small
#
# -----------------------------------------------------------------

# LLM Provider Selection
LLM_PROVIDER=groq  # Options: groq, huggingface, cohere, mistral, openai, anthropic

# Groq Configuration (RECOMMENDED - Free tier)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Hugging Face Configuration (Free tier)
HF_TOKEN=hf_your-huggingface-token-here
HF_MODEL=meta-llama/Llama-3.3-70B-Instruct

# Cohere Configuration (Free trial)
COHERE_API_KEY=your-cohere-api-key-here
COHERE_MODEL=command-r-plus

# Mistral Configuration (Free tier)
MISTRAL_API_KEY=your-mistral-api-key-here
MISTRAL_MODEL=mistral-large-latest

# OpenAI API Configuration (PAID - fallback)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview

# Anthropic API (PAID - fallback)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Vector Database (Using free embedding model)
CHROMA_DB_PATH=./data/chroma_db
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# PostgreSQL Database (For production, use managed DB like Neon, Supabase, etc.)
DATABASE_URL=postgresql://user:password@localhost:5432/claims_db

# LangFuse Evaluation (optional - free tier available)
LANGFUSE_PUBLIC_KEY=pk-langfuse-public-key
LANGFUSE_SECRET_KEY=sk-langfuse-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO
