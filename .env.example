# Environment Configuration
# Copy this file to .env and fill in your values

# OpenAI API Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview

# Anthropic API (optional - for Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Vector Database
CHROMA_DB_PATH=./data/chroma_db
EMBEDDING_MODEL=text-embedding-3-small

# PostgreSQL Database
DATABASE_URL=postgresql://user:password@localhost:5432/claims_db

# LangFuse Evaluation (optional)
LANGFUSE_PUBLIC_KEY=pk-langfuse-public-key
LANGFUSE_SECRET_KEY=sk-langfuse-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO
